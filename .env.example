# Zotero API Credentials
# Get these from: https://www.zotero.org/settings/keys
ZOTERO_LIBRARY_ID="your_library_id_here"
ZOTERO_API_KEY="your_api_key_here"

# (Optional) If you want to upload to a specific Group library instead of your personal library
# ZOTERO_LIBRARY_TYPE="group" # Default is 'user'

# (Optional) API keys for literature search sources to increase rate limits
S2_API_KEY="your_semantic_scholar_api_key"
CORE_API_KEY="your_core_api_key"